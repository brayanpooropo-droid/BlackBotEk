<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a1a">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- SECCIÓN: BLOQUEAR ZONAS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bloquear Zonas"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="15dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dibuja las zonas donde NO quieres aceptar viajes"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginBottom="10dp" />

        <!-- Google Maps para Bloquear Zonas -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:background="#2a2a2a"
            android:layout_marginBottom="20dp">

            <com.google.android.gms.maps.MapView
                android:id="@+id/mapBloquearZonas"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="10dp"
                android:background="#00000080">

                <Button
                    android:id="@+id/btnDibujarZona"
                    android:layout_width="wrap_content"
                    android:layout_height="45dp"
                    android:text="✏️ Dibujar Zona"
                    android:textSize="12sp"
                    android:background="#FF6B6B"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="10dp" />

                <Button
                    android:id="@+id/btnLimpiarZonas"
                    android:layout_width="wrap_content"
                    android:layout_height="45dp"
                    android:text="🗑️ Limpiar"
                    android:textSize="12sp"
                    android:background="#444444"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </FrameLayout>

        <!-- SECCIÓN: MODO RETORNO A CASA -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Modo Retorno a Casa"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="15dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Marca tu hogar y el radio de llegada"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginBottom="10dp" />

        <!-- Google Maps para Retorno a Casa -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:background="#2a2a2a"
            android:layout_marginBottom="20dp">

            <com.google.android.gms.maps.MapView
                android:id="@+id/mapRetornoACasa"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <Button
                android:id="@+id/btnConfirmarPunto"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_gravity="bottom"
                android:text="✓ Confirmar Punto"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="#4CAF50"
                android:textColor="#FFFFFF"
                android:layout_margin="10dp" />
        </FrameLayout>

        <!-- Radio de Llegada -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#2a2a2a"
            android:padding="15dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Radio de llegada (KM):"
                android:textSize="14sp"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/txtRadioLlegada"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2 KM"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#00FF00" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/sliderRadioLlegada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="1"
            android:max="10"
            android:progress="2"
            android:layout_marginBottom="20dp" />

        <!-- SECCIÓN: MODO HORA PICO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#2a2a2a"
            android:padding="15dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚡ Modo Hora Pico"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchHoraPico"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Multiplicador Hora Pico -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#2a2a2a"
            android:padding="15dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Multiplicador (%)"
                android:textSize="14sp"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/txtMultiplicador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20%"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FF9800" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/sliderMultiplicador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="5"
            android:max="100"
            android:progress="20"
            android:layout_marginBottom="30dp" />

        <!-- Botón Guardar -->
        <Button
            android:id="@+id/btnGuardarFiltros"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="GUARDAR FILTROS"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="#00FF00"
            android:textColor="#000000" />

    </LinearLayout>

</ScrollView>

